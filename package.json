{
  "name": "duckdb-notebook",
  "displayName": "DuckDB Jupyter Kernel",
  "description": "DuckDB SQL kernel for Jupyter notebooks with language server support",
  "version": "0.4.0",
  "publisher": "duckdb-notebook",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jianyexi/vscode-duckdb-notebook.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Notebooks", "Programming Languages"],
  "keywords": ["duckdb", "sql", "notebook", "database"],
  "activationEvents": [
    "onNotebook:jupyter-notebook"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "duckdb-sql",
        "aliases": ["DuckDB SQL", "duckdb"],
        "extensions": [".duckdb-sql"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "duckdb-sql",
        "scopeName": "source.sql",
        "path": "./syntaxes/duckdb-sql.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "duckdb-notebook.new",
        "title": "New DuckDB Jupyter Notebook",
        "category": "DuckDB"
      },
      {
        "command": "duckdb-notebook.downloadBinary",
        "title": "Download DuckDB Binary",
        "category": "DuckDB"
      }
    ],
    "configuration": {
      "title": "DuckDB Notebook",
      "properties": {
        "duckdb-notebook.maxRows": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of rows to display in query results"
        },
        "duckdb-notebook.databasePath": {
          "type": "string",
          "default": ":memory:",
          "description": "Path to DuckDB database file (use :memory: for in-memory)"
        },
        "duckdb-notebook.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom DuckDB binary. Set to 'auto' to download automatically. Leave empty to use built-in @duckdb/node-api."
        },
        "duckdb-notebook.binaryVersion": {
          "type": "string",
          "default": "",
          "description": "DuckDB version to download (e.g. 'v1.2.0'). Leave empty for latest."
        },
        "duckdb-notebook.languageServer.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "lint": "eslint src/ server/ --ext ts"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.0-r.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
